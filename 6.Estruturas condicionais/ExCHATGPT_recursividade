// 💪 EX Rec-2 — Soma recursiva //
// 👉 receba um número n
// 👉 retorne a soma de todos os números de 1 até n

function somarAte(a) {
  if (a === 1) {
    return 1;
  } else {
    return a + somarAte(a - 1);
  }
}
console.log(somarAte(5));
console.log('FIM EX2');

// 🧠 💪 EX Rec-3 — Fibonacci (início guiado)
// Crie uma função recursiva que retorne o número de Fibonacci de n.  // F(n) = F(n - 1) + F(n - 2)
// if n == 0 → retorna 0
// if n == 1 → retorna 1
// senão → F(n) = F(n-1) + F(n-2)

function fib(n) {
  if (n === 0) {
    return 0;
  } else if (n === 1) {
    return 1;
  } else {
    return fib(n - 1) + fib(n - 2);
  }
}

console.log(fib(4));
console.log('FIM EX3');

