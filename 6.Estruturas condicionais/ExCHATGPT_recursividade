// 🧠 💪 EX Rec-7 — Contagem crescente (versão recursiva)
function contCrescente(a, b) {
  console.log(a);
  if (a === b) {
    return 1;
  } else {
    return contCrescente(a + 1, b);
  }
}
contCrescente(1, 5);
console.log('FIM EX7');

